{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://policing-platform.local/schemas/knowledge-ingestion-event.schema.json",
  "title": "Platform Knowledge Ingestion Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "event_type",
    "occurred_at",
    "producer",
    "correlation_id",
    "synthetic_data",
    "source_record",
    "classification",
    "retrieval_scope",
    "redaction_decision",
    "citation_source",
    "content"
  ],
  "properties": {
    "schema_version": {
      "const": "platform.knowledge_ingestion_event.v1"
    },
    "event_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128
    },
    "event_type": {
      "enum": [
        "knowledge.source.upsert_requested",
        "knowledge.source.delete_requested",
        "knowledge.source.snapshot_requested"
      ]
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["service", "domain", "source_system", "projection_version", "policy_version"],
      "properties": {
        "service": { "type": "string", "minLength": 1, "maxLength": 80 },
        "domain": { "type": "string", "minLength": 1, "maxLength": 80 },
        "source_system": { "type": "string", "minLength": 1, "maxLength": 80 },
        "projection_version": { "type": "string", "minLength": 1, "maxLength": 80 },
        "policy_version": { "type": "string", "minLength": 1, "maxLength": 80 }
      }
    },
    "correlation_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128
    },
    "synthetic_data": {
      "type": "boolean",
      "description": "P10 fixtures must set this to true. Later production ingestion must be approved by a separate phase."
    },
    "source_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resource_kind",
        "resource_id",
        "source_record_id",
        "source_version",
        "projection_version",
        "projected_at",
        "source_status",
        "snapshot_version"
      ],
      "properties": {
        "resource_kind": { "enum": ["platform_case", "platform_evidence", "legal_document", "complaint_document", "forensic_report", "social_evidence_package"] },
        "resource_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "source_record_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "source_version": { "type": "string", "minLength": 1, "maxLength": 128 },
        "projection_version": { "type": "string", "minLength": 1, "maxLength": 128 },
        "projected_at": { "type": "string", "format": "date-time" },
        "source_status": { "enum": ["active", "deleted", "sealed", "purged", "superseded", "retained_inaccessible"] },
        "snapshot_version": { "type": "string", "minLength": 1, "maxLength": 128 },
        "content_hash_sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" }
      }
    },
    "classification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "pii_profile", "legal_hold_status"],
      "properties": {
        "level": { "enum": ["public", "restricted", "confidential", "secret"] },
        "pii_profile": { "enum": ["none", "masked", "contains_pii", "unknown"] },
        "legal_hold_status": { "enum": ["none", "active", "released"] },
        "compartments": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 80 },
          "uniqueItems": true
        }
      }
    },
    "retrieval_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["org_id", "jurisdiction", "assignment", "allowed_purposes"],
      "properties": {
        "org_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "unit_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "jurisdiction": {
          "type": "object",
          "additionalProperties": false,
          "required": ["country", "state"],
          "properties": {
            "country": { "type": "string", "minLength": 2, "maxLength": 2 },
            "state": { "type": "string", "minLength": 2, "maxLength": 80 },
            "district": { "type": "string", "minLength": 1, "maxLength": 128 },
            "police_station": { "type": "string", "minLength": 1, "maxLength": 128 }
          }
        },
        "assignment": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "case_id": { "type": "string", "minLength": 1, "maxLength": 128 },
            "evidence_id": { "type": "string", "minLength": 1, "maxLength": 128 },
            "queue_id": { "type": "string", "minLength": 1, "maxLength": 128 }
          }
        },
        "allowed_purposes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1, "maxLength": 80 },
          "uniqueItems": true
        }
      }
    },
    "redaction_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "fields_redacted", "storage_uri_exposed", "reason"],
      "properties": {
        "profile": { "type": "string", "minLength": 1, "maxLength": 80 },
        "fields_redacted": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 128 },
          "uniqueItems": true
        },
        "storage_uri_exposed": { "const": false },
        "reason": { "type": "string", "minLength": 1, "maxLength": 160 }
      }
    },
    "citation_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["citation_id", "title", "citation_label", "citation_filter_required"],
      "properties": {
        "citation_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "title": { "type": "string", "minLength": 1, "maxLength": 240 },
        "citation_label": { "type": "string", "minLength": 1, "maxLength": 160 },
        "page_number": { "type": ["integer", "null"], "minimum": 1 },
        "chunk_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "citation_filter_required": { "const": true }
      }
    },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": ["content_mode"],
      "properties": {
        "content_mode": { "enum": ["metadata_only", "external_object_ref", "inline_synthetic_text"] },
        "object_ref": { "type": "string", "minLength": 1, "maxLength": 512 },
        "synthetic_text": { "type": "string", "maxLength": 20000 },
        "language": { "type": "string", "minLength": 2, "maxLength": 16 }
      }
    }
  }
}
