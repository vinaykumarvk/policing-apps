    { "stateId": "IN_REVIEW", "type": "active", "taskRequired": true, "roleId": "LEGAL_REVIEWER", "slaDays": 3 },
    { "stateId": "APPROVED", "type": "active", "taskRequired": true, "roleId": "SUPERVISOR" },
    { "stateId": "EXPORTED", "type": "terminal", "taskRequired": false },
    { "stateId": "SUPERSEDED", "type": "terminal", "taskRequired": false },
    { "stateId": "GENERATION_FAILED", "type": "active", "taskRequired": false }
  ],
  "transitions": [
