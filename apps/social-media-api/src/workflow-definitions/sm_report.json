    { "transitionId": "APPROVE", "fromStateId": "IN_REVIEW", "toStateId": "APPROVED", "trigger": "manual", "guards": [{ "type": "ACTOR_ROLE", "params": { "roles": ["LEGAL_REVIEWER", "SUPERVISOR"] } }] },
