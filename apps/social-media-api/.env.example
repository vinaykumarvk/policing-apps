# Social Media Intelligence API Configuration

# Database
SM_DATABASE_URL=postgres://puda:puda@localhost:5432/social_media

# Server
SM_API_PORT=3004
SM_API_HOST=0.0.0.0

# Authentication
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=24h

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3020

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# Runtime
NODE_ENV=development
LOG_QUERIES=false
SHUTDOWN_TIMEOUT_MS=15000
