    { "transitionId": "SUBMIT_EXT", "fromStateId": "REPORT_READY", "toStateId": "SUBMITTED", "trigger": "manual", "guards": [{ "type": "ACTOR_ROLE", "params": { "roles": ["SUPERVISOR"] } }] },
    { "transitionId": "CLOSE_SUBMITTED", "fromStateId": "SUBMITTED", "toStateId": "CLOSED", "trigger": "manual", "guards": [{ "type": "ACTOR_ROLE", "params": { "roles": ["SUPERVISOR", "ADMINISTRATOR"] } }] },
    { "transitionId": "CLOSE_REVIEW", "fromStateId": "UNDER_REVIEW", "toStateId": "CLOSED", "trigger": "manual", "guards": [{ "type": "ACTOR_ROLE", "params": { "roles": ["SUPERVISOR", "ADMINISTRATOR"] } }] },
    { "transitionId": "CLOSE_REPORT", "fromStateId": "REPORT_READY", "toStateId": "CLOSED", "trigger": "manual", "guards": [{ "type": "ACTOR_ROLE", "params": { "roles": ["SUPERVISOR", "ADMINISTRATOR"] } }] },
    { "transitionId": "REOPEN", "fromStateId": "CLOSED", "toStateId": "REOPENED", "trigger": "manual", "guards": [{ "type": "ACTOR_ROLE", "params": { "roles": ["SUPERVISOR", "ADMINISTRATOR"] } }] },
    { "transitionId": "RESUME", "fromStateId": "REOPENED", "toStateId": "UNDER_REVIEW", "trigger": "manual", "guards": [{ "type": "ACTOR_ROLE", "params": { "roles": ["FORENSIC_ANALYST"] } }] }
  ]
