# DOPAMS API Configuration

# Database
DOPAMS_DATABASE_URL=postgres://puda:puda@localhost:5432/dopams

# Server
DOPAMS_API_PORT=3002
DOPAMS_API_HOST=0.0.0.0

# Authentication
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=24h

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3021

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# Runtime
NODE_ENV=development
LOG_QUERIES=false
SHUTDOWN_TIMEOUT_MS=15000
