    { "transitionId": "CLOSE", "fromStateId": "RESOLVED", "toStateId": "CLOSED", "trigger": "manual", "guards": [{ "type": "ACTOR_ROLE", "params": { "roles": ["SUPERVISORY_OFFICER"] } }] },
    { "transitionId": "FALSE_POS", "fromStateId": "ASSIGNED", "toStateId": "FALSE_POSITIVE", "trigger": "manual" },
    { "transitionId": "AUTO_ESCALATE", "fromStateId": "ASSIGNED", "toStateId": "ESCALATED", "trigger": "system" }
