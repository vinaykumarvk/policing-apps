    { "transitionId": "APPROVE", "fromStateId": "REVIEW_PENDING", "toStateId": "APPROVED", "trigger": "manual", "guards": [{ "type": "ACTOR_ROLE", "params": { "roles": ["SUPERVISORY_OFFICER", "ZONAL_OFFICER"] } }] },
